{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/sw.js", "destination": "/public/sw.js" },
    { "source": "/icon-192.png", "destination": "/public/icon-192.png" },
    { "source": "/badge-72.png", "destination": "/public/badge-72.png" },
    { "source": "/_poxy-staff-mcu", "destination": "/assets/admin-terminal.html" },
    { "source": "/_poxy-staff-mcu/", "destination": "/assets/admin-terminal.html" },
    { "source": "/lumina-os", "destination": "/index.html" },
    { "source": "/lumina-os/", "destination": "/index.html" },
    { "source": "/lumina-os/:path*", "destination": "/index.html" },
    { "source": "/chat/app", "destination": "/index.html" },
    { "source": "/chat/app/", "destination": "/index.html" },
    { "source": "/chat/app/:path*", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/admin-terminal", "destination": "/", "permanent": false },
    { "source": "/admin-terminal/:path*", "destination": "/", "permanent": false },
    { "source": "/assets/admin-terminal.html", "destination": "/", "permanent": false },
    { "source": "/stitch-export/(.*)", "destination": "/", "permanent": false },
    { "source": "/supabase/(.*)", "destination": "/", "permanent": false },
    { "source": "/tools/(.*)", "destination": "/", "permanent": false }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/public/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/_poxy-staff-mcu",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
